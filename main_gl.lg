(require 'glplat)

(ns xsofy.main-gl
  "GL frontend main loop with level-2 transition and first-person mode.
   Presentation state machine: :top-down (default) → :falling (anim) → :fp.
   Game logic unchanged; animation/input remapping are presentation-only.
   Input: PollInputEvents → input remapping (FP-specific) → dispatch → bridge → grid-verts → submit"
  (:require
   [os]
   [string]
   [xsofy.dispatch :as dispatch]
   [xsofy.gl.bridge :as bridge]
   [xsofy.gl.fall :as fall]
   [xsofy.gl.fpview :as fpview]
   [xsofy.gl.grid :as grid]
   [xsofy.gl.hud :as hud]
   [xsofy.gl.mat4 :as mat4]
   [xsofy.gl.vfx :as vfx]
   [xsofy.input :as input]
   [xsofy.terrain :as terrain]
   [xsofy.title :as title]
   [xsofy.world :as world]))

;; ==========================================================
;; Atlas Loading
;; ==========================================================

(defn read-atlas-edn
  "Read atlas.edn as a map of glyph-char -> [u0 v0 u1 v1].
   The file is a plain EDN map literal, so the reader parses it directly
   (same slurp/read-string path save.lg uses for persistence)."
  [path]
  (let [atlas (read-string (slurp path))]
    (when-not (map? atlas)
      (println "read-atlas-edn: unexpected atlas format in" path))
    atlas))

;; ==========================================================
;; Utilities
;; ==========================================================

(defn parse-number
  "Parse a numeric string via the reader; default when missing or malformed.
   (The dialect has no string->int fns; read-string is the reliable path.)"
  [s default]
  (or (when (and s (> (count s) 0))
        (let [n (try (read-string s) (catch _ nil))]
          (when (number? n) n)))
      default))

;; ==========================================================
;; Auto-Action Helpers (pure logic from xsofy.play)
;; ==========================================================

(defn auto-key-for
  "The implicit action for an in-flight auto-mode, or nil if not auto-moving.
   Replicates xsofy.play/auto-key-for to avoid requiring that module (it depends
   on term, which isn't available in GL context)."
  [world]
  (cond
    (:resting world) :wait
    (:running-dir world) (let [[dx dy] (:running-dir world)]
                           (cond (and (= dx 0) (< dy 0)) :up
                                 (and (= dx 0) (> dy 0)) :down
                                 (and (< dx 0) (= dy 0)) :left
                                 (and (> dx 0) (= dy 0)) :right
                                 :else nil))
    (:autoexploring world) :autoexplore
    (:auto-target world) :auto-target-step
    :else nil))

(defn apply-auto-stops
  "Stop an active auto-mode when something interesting happens — death, a
   visible threatening enemy, finished resting, a blocked run, or a full
   inventory. `world` is the pre-turn world (for the run-blocked turn check).
   Replicates xsofy.play/apply-auto-stops to avoid requiring that module."
  [new-world world]
  (if (or (:resting new-world)
          (:running-dir new-world)
          (:autoexploring new-world)
          (:auto-target new-world))
    (let [player (get-in new-world [:entities :player])
          hp (get-in player [:body :hp] 0)
          max-hp (get-in player [:body :max-hp] 1)
          fov (or (:fov new-world) #{})
          enemies (some (fn [e]
                          (and (:ai e)
                               (not= :player (:id e))
                               (:pos e)
                               (contains? fov (:pos e))
                               (contains? #{:hunt :investigate :flee}
                                 (get-in e [:ai :state]))))
                        (vals (:entities new-world)))
          run-blocked (and (or (:running-dir new-world) (:autoexploring new-world))
                           (= (:turn new-world) (:turn world)))
          dead (nil? player)]
      (cond
        dead (dissoc new-world :resting :running-dir :autoexploring :auto-target)
        enemies (-> new-world
                    (dissoc :resting :running-dir :autoexploring :auto-target)
                    (world/log-msg "You stop — enemy spotted!"))
        (and (:resting new-world) (>= hp max-hp))
        (-> new-world (dissoc :resting) (world/log-msg "You finish resting."))
        run-blocked (dissoc new-world :running-dir :autoexploring :auto-target)
        (:inventory-full new-world)
        (-> new-world
            (dissoc :autoexploring :auto-target :inventory-full))
        :else new-world))
    new-world))

;; ==========================================================
;; Input Parsing
;; ==========================================================

(defn parse-glplat-event
  "Parse a glplat event string (e.g., 'key:w', 'key:escape', 'char:x') to a key string
   that input/parse-key can consume."
  [event-str]
  (cond
    (string/starts-with? event-str "key:escape") ""
    (string/starts-with? event-str "key:") (let [key (subs event-str 4)]
                                             (case key
                                               "up" "[A"
                                               "down" "[B"
                                               "left" "[D"
                                               "right" "[C"
                                               key))  ;; fallback to raw key
    (string/starts-with? event-str "key-repeat:") (subs event-str 11)
    (string/starts-with? event-str "char:") (subs event-str 5)
    :else nil))

;; ==========================================================
;; Build Game State
;; ==========================================================

(defn build-game-direct
  "Build a fresh game state from a seed, without the title screen."
  [seed]
  (let [rng {:seed seed}
        [title rng] (title/generate-title rng)
        [scheme rng] (title/pick-scheme rng)
        [quest rng] (title/generate-quest rng)
        seed-out seed]
    (-> (world/make-world 79 30 seed-out)
        (assoc :title title
               :scheme scheme
               :quest-item (:item quest)
               :running true)
        (#(reduce world/log-msg % (:messages quest))))))

;; ==========================================================
;; Matrix Helpers
;; ==========================================================

(defn build-top-down-mvp
  "Build MVP for top-down view: rotate xz-ground into xy-plane, then project.
   Grid is on xz plane (y=0); rotate-x(π/2) maps (x,0,z) → (x,-z,0).
   Then ortho projects [0,39.5]×[-30,0]×[-1,1] → [-1,1]³."
  []
  (let [rot-90 (mat4/rotate-x (/ 3.14159265359 2.0))
        ortho (mat4/ortho 0.0 39.5 -30.0 0.0 -1.0 1.0)]
    (mat4/mul ortho rot-90)))

(defn project-world-point
  "Project a world point through an MVP matrix to normalized device coordinates.
   Returns [x_ndc y_ndc z_ndc] by dividing by homogeneous w component."
  [mvp [x y z]]
  (let [v4 (mat4/mul-v mvp [x y z 1.0])
        w (get v4 3)
        w-safe (if (zero? w) 1.0 w)]
    [(/ (get v4 0) w-safe) (/ (get v4 1) w-safe) (/ (get v4 2) w-safe)]))

;; ==========================================================
;; Presentation State Machine
;; ==========================================================

(defn make-pres-state
  "Create initial presentation state (top-down mode, no animation)."
  []
  {:mode :top-down        ; :top-down | :falling | :fp
   :facing :north         ; Current facing direction (:north/:south/:east/:west)
   :fall-start nil        ; Wall-clock time fall animation started (if :falling)
   :fall-duration 2.5})   ; Duration in seconds

(defn advance-pres-state
  "Advance presentation state machine: check for depth change, update animations."
  [pres-state world prev-world current-time force-fall-at]
  (let [depth (:depth world)
        prev-depth (:depth prev-world)
        in-falling-window (and (some? force-fall-at)
                               (>= current-time force-fall-at)
                               (< current-time (+ force-fall-at 3.0)))]
    (cond
      ;; Depth increased (or forced): start falling — only from top-down,
      ;; else the 3s force window re-arms :fall-start every frame and the
      ;; animation stays pinned at t=0.
      (and (= (:mode pres-state) :top-down)
           (or (> depth prev-depth) in-falling-window))
      (assoc pres-state :mode :falling :fall-start current-time)

      ;; If in falling mode, check if animation complete
      (= (:mode pres-state) :falling)
      (let [fall-time (- current-time (:fall-start pres-state))
            fall-t (min 1.0 (/ fall-time (:fall-duration pres-state)))]
        (if (>= fall-t 1.0)
          (assoc pres-state :mode :fp)  ; Animation complete, enter FP
          pres-state))

      :else pres-state)))

;; ==========================================================
;; Rendering Helpers
;; ==========================================================

(defn is-wall-tile [tile]
  "Check if a tile should be rendered as a 3D wall."
  (or (= tile 8) (= tile 9)))  ; wall-stone and wall-torch

(defn build-wall-batch
  "Collect wall vertices for all wall cells in the visible grid."
  [world atlas]
  (let [{:keys [terrain width height fov]} world
        verts (atom [])]
    (dotimes [row height]
      (dotimes [col width]
        (when (contains? fov [col row])
          (let [tile (terrain/tget terrain width col row)]
            (when (is-wall-tile tile)
              (let [wall-verts (grid/wall-extrude-verts
                                 {:col col :row row :glyph (get terrain/tile-chars tile "?")}
                                 1.0 atlas {:cell-w 0.5 :cell-h 1.0})]
                (when (seq wall-verts)
                  (swap! verts concat wall-verts))))))))
    (vec @verts)))

(defn build-entity-batch
  "Collect entity billboard vertices for visible entities (not player)."
  [world atlas yaw]
  (let [{:keys [entities fov]} world
        ents (filter #(and (not= :item (:entity-type %))
                           (not= :player (:id %)))
                     (vals entities))
        verts (atom [])]
    (doseq [ent ents]
      (when-let [pos (:pos ent)]
        (when (contains? fov pos)
          (let [glyph (get-in ent [:visual :glyph] "?")
                fg (get-in ent [:visual :color] [200 60 60])
                entity-cell {:col (nth pos 0) :row (nth pos 1) :glyph glyph :fg fg}
                bill-verts (fpview/entity-billboard entity-cell yaw atlas {:cell-w 0.5 :cell-h 1.0})]
            (when (seq bill-verts)
              (swap! verts concat bill-verts))))))
    (vec @verts)))

(defn lerp-matrix-component
  "Component-wise linear interpolation between two matrices."
  [m0 m1 t]
  (vec (map (fn [i] (+ (get m0 i) (* t (- (get m1 i) (get m0 i)))))
            (range 16))))

(defn render-top-down
  "Render top-down view with ortho projection (xz-ground mapped to screen via rotate-x).
   Verify clip-space projection with two test points: cell (0,0) and cell (0,29)."
  [world tex-id atlas dump? frame vfx]
  (let [map-rect {:x 0 :y 0 :w (:width world) :h (:height world)}
        cells (bridge/grid-cells world map-rect)
        {:keys [bg glyphs]} (grid/grid-verts cells atlas {:cell-w 0.5 :cell-h 1.0})
        bg-count (quot (count bg) 9)
        glyph-count (quot (count glyphs) 9)

        ;; Build correct MVP
        mvp (build-top-down-mvp)

        ;; Test projection: cell corners in world space
        ;; Cell (0,0): corner at (0, 0, 0)
        ;; Cell (0,29): corner at (0, 0, 29)
        ;; Cell (78,0): corner at (39.5, 0, 0)
        pt-00 (project-world-point mvp [0.0 0.0 0.0])
        pt-0-29 (project-world-point mvp [0.0 0.0 29.0])
        pt-78-0 (project-world-point mvp [39.5 0.0 0.0])]

    (glplat/SetMatrix mvp)

    (when dump?
      (when (= frame 0)
        (print (str "XSOFY_GL_DUMP: top-down frame 0\n"))
        (print (str "  bg-batch: " (count bg) " floats, " bg-count " vertices\n"))
        (print (str "  glyph-batch: " (count glyphs) " floats, " glyph-count " vertices\n"))
        (print (str "  total cells: " (count cells) "\n"))
        (print (str "  CLIP-SPACE PROJECTION TEST:\n"))
        (print (str "    cell (0,0) @ (0,0,0) → clip " pt-00 "\n"))
        (print (str "    cell (0,29) @ (0,0,29) → clip " pt-0-29 "\n"))
        (print (str "    cell (78,0) @ (39.5,0,0) → clip " pt-78-0 "\n"))
        ;; Sanity checks
        (when-not (and (>= (nth pt-00 0) -1.0) (<= (nth pt-00 0) 1.0))
          (print "WARN: pt-00 x out of clip bounds\n"))
        (when-not (and (>= (nth pt-0-29 0) -1.0) (<= (nth pt-0-29 0) 1.0))
          (print "WARN: pt-0-29 x out of clip bounds\n"))
        (when-not (> (nth pt-00 1) (nth pt-0-29 1))
          (print "WARN: row 0 clip-y should be > row 29 clip-y (inverted y-screen)\n"))))

    ;; Submit batches
    (when (seq bg)
      (glplat/SubmitTriangles 0 bg))
    (when (seq glyphs)
      (glplat/SubmitTriangles tex-id glyphs))
    ;; Submit VFX
    (let [{:keys [tinted glyphs]} (vfx/vfx-verts vfx atlas {:cell-w 0.5
                                                            :cell-h 1.0})]
      (when (seq tinted)
        (glplat/SubmitTriangles 0 tinted))
      (when (seq glyphs)
        (glplat/SubmitTriangles tex-id glyphs)))))

(defn render-falling
  "Render morphing view: blended camera, tilted geometry, extruding walls."
  [world pres-state current-time tex-id atlas dump? vfx]
  (let [fall-time (- current-time (:fall-start pres-state))
        fall-duration (:fall-duration pres-state)
        fall-t (min 1.0 (/ fall-time fall-duration))

        ;; Grid setup
        map-rect {:x 0 :y 0 :w (:width world) :h (:height world)}
        cells (bridge/grid-cells world map-rect)
        {:keys [bg glyphs]} (grid/grid-verts cells atlas {:cell-w 0.5 :cell-h 1.0})

        ;; Player position for morph
        [px py] (get-in world [:entities :player :pos])
        grid-w (:width world)
        grid-h (:height world)

        ;; Get morph parameters
        morph-params (fall/morph {:t fall-t :grid-w grid-w :grid-h grid-h
                                  :player [px py] :heading (:facing pres-state)})
        {:keys [plane-tilt-rad wall-height camera projection-blend]} morph-params

        ;; Build ortho and perspective MVPs. The ortho end must equal the
        ;; top-down MVP exactly, or the view pops when the fall starts.
        mvp-ortho (build-top-down-mvp)

        ;; Perspective MVP
        fovy (* 70.0 (/ 3.14159265359 180.0))  ; 70 degrees in radians
        aspect (/ 800.0 600.0)
        proj-pers (mat4/perspective fovy aspect 0.05 60.0)
        view-pers (mat4/look-at (:eye camera) (:target camera) (:up camera))
        mvp-pers (mat4/mul proj-pers view-pers)

        ;; Blend MVP. The geometry already lives in the 3D world (floor on
        ;; xz plane), so the camera descent + projection blend IS the
        ;; tip-over. Rotating the model by plane-tilt-rad as well would
        ;; double the tilt and stand the floor up vertically at t=1;
        ;; the morph's tilt value only drives wall extrusion timing now.
        final-mvp (lerp-matrix-component mvp-ortho mvp-pers projection-blend)

        ;; Floor quads (untilted still)
        bg-count (quot (count bg) 9)
        glyph-count (quot (count glyphs) 9)

        ;; Wall batch
        wall-verts (build-wall-batch world atlas)
        wall-count (quot (count wall-verts) 9)]

    (glplat/SetMatrix final-mvp)

    (when dump?
      (when (or (< fall-t 0.01) (and (> fall-t 0.45) (< fall-t 0.55)))
        (print (str "XSOFY_GL_DUMP: falling frame t=" (format "%.2f" fall-t) "\n"))
        (print (str "  plane-tilt-rad: " (format "%.3f" plane-tilt-rad) "\n"))
        (print (str "  wall-height: " (format "%.3f" wall-height) "\n"))
        (print (str "  camera eye: " (:eye camera) "\n"))
        (print (str "  bg-batch: " bg-count " verts, wall-batch: " wall-count " verts\n"))
        (when (and (seq wall-verts) (= wall-count 0))
          (print "WARN: wall-verts non-empty but wall-count is 0\n"))
        (when (and (> (count wall-verts) 0) (= wall-count 0))
          (print "WARN: walls expected but wall-count is 0\n"))))

    ;; Submit batches in order: bg, walls, glyphs
    (when (seq bg)
      (glplat/SubmitTriangles 0 bg))
    (when (seq wall-verts)
      (glplat/SubmitTriangles tex-id wall-verts))
    (when (seq glyphs)
      (glplat/SubmitTriangles tex-id glyphs))
    ;; Submit VFX
    (let [{:keys [tinted glyphs]} (vfx/vfx-verts vfx atlas {:cell-w 0.5
                                                            :cell-h 1.0})]
      (when (seq tinted)
        (glplat/SubmitTriangles 0 tinted))
      (when (seq glyphs)
        (glplat/SubmitTriangles tex-id glyphs)))))

(defn render-first-person
  "Render first-person view: perspective camera, billboarded entities."
  [world pres-state tex-id atlas dump? frame vfx]
  (let [;; Player position
        [px py] (get-in world [:entities :player :pos])
        facing (:facing pres-state)

        ;; Camera pose
        pose (fpview/fp-camera-pose [px py] facing)
        fovy (* 70.0 (/ 3.14159265359 180.0))  ; 70 degrees in radians
        aspect (/ 800.0 600.0)
        proj (mat4/perspective fovy aspect 0.05 60.0)
        view (mat4/look-at (:eye pose) (:target pose) (:up pose))
        mvp (mat4/mul proj view)

        ;; Geometry
        map-rect {:x 0 :y 0 :w (:width world) :h (:height world)}
        cells (bridge/grid-cells world map-rect)
        {:keys [bg glyphs]} (grid/grid-verts cells atlas {:cell-w 0.5 :cell-h 1.0})

        ;; Walls: only render visible wall cells
        wall-verts (build-wall-batch world atlas)

        ;; Billboards for entities
        yaw (fpview/facing-to-angle facing)
        entity-verts (build-entity-batch world atlas yaw)

        bg-count (quot (count bg) 9)
        glyph-count (quot (count glyphs) 9)
        wall-count (quot (count wall-verts) 9)
        entity-count (quot (count entity-verts) 9)]

    (glplat/SetMatrix mvp)

    (when dump?
      (when (= frame 0)
        (print (str "XSOFY_GL_DUMP: first-person frame 0\n"))
        (print (str "  camera eye: " (:eye pose) "\n"))
        (print (str "  facing: " facing "\n"))
        (print (str "  bg-batch: " bg-count " verts\n"))
        (print (str "  wall-batch: " wall-count " verts\n"))
        (print (str "  entity-batch: " entity-count " verts\n"))
        (when (= entity-count 0)
          (print "INFO: no entity billboards in frame (ok for empty level)\n"))))

    ;; Submit batches: floors, walls, entities, glyphs
    (when (seq bg)
      (glplat/SubmitTriangles 0 bg))
    (when (seq wall-verts)
      (glplat/SubmitTriangles tex-id wall-verts))
    (when (seq entity-verts)
      (glplat/SubmitTriangles tex-id entity-verts))
    (when (seq glyphs)
      (glplat/SubmitTriangles tex-id glyphs))
    ;; Submit VFX
    (let [{:keys [tinted glyphs]} (vfx/vfx-verts vfx atlas {:cell-w 0.5
                                                            :cell-h 1.0})]
      (when (seq tinted)
        (glplat/SubmitTriangles 0 tinted))
      (when (seq glyphs)
        (glplat/SubmitTriangles tex-id glyphs)))))

(defn render-hud
  "Screen-space HUD overlay pass, drawn after the scene each frame.
   hud.lg builds quads in screen-cell space (79×30, y down, z=0); the ortho
   here uses near=0 so those quads land at NDC depth -1 — in front of all
   scene geometry under the LEQUAL depth test (SubmitTriangles draws
   immediately with the current matrix, so a mid-frame SetMatrix is safe)."
  [world tex-id atlas]
  (let [{:keys [solids glyphs]} (hud/hud-verts world atlas {:cell-w 0.5 :cell-h 1.0})
        hud-mvp (mat4/ortho 0.0 39.5 30.0 0.0 0.0 1.0)]
    (glplat/SetMatrix hud-mvp)
    (when (seq solids)
      (glplat/SubmitTriangles 0 solids))
    (when (seq glyphs)
      (glplat/SubmitTriangles tex-id glyphs))))

(defn apply-screenfx-tint
  "Draw a full-screen tint quad if there's an active flash effect.
   Rendered last with z=-0.999 for depth handling."
  [world tex-id]
  ;; TODO: screenfx accessor + tint quad rendering
  ;; Placeholder for now (no active flashes in Level 1)
  nil)

;; ==========================================================
;; Main Loop
;; ==========================================================

(defn -main []
  ;; Mark GL mode BEFORE any worldgen: title/show-descending-screen no-ops on
  ;; this var — otherwise descending animates runes into the launching
  ;; terminal (term/size succeeds there) and stalls the GL window.
  (os/setenv "XSOFY_GL_FRONTEND" "1")
  (let [;; Parse environment / args
        seed-str (or (os/getenv "XSOFY_SEED") "0")
        seed (parse-number seed-str 0)
        auto-exit-str (os/getenv "XSOFY_GL_AUTOEXIT")
        auto-exit-secs (when auto-exit-str
                         (let [d (parse-number auto-exit-str 0.0)]
                           (when (> d 0.0) d)))
        dump? (boolean (os/getenv "XSOFY_GL_DUMP"))
        force-fall-str (os/getenv "XSOFY_GL_FORCE_FALL")
        force-fall-secs (when force-fall-str
                          (parse-number force-fall-str -1.0))

        ;; Initialize GL
        _ (glplat/Init 800 600 "xsofy — GL Frontend")
        tex-id (glplat/LoadTextureFile "assets/gl/atlas.png")
        atlas (read-atlas-edn "assets/gl/atlas.edn")

        ;; Build initial game state
        world (build-game-direct seed)
        start-time (glplat/Time)

        ;; Compute force-fall trigger time (absolute wall-clock, or nil)
        force-fall-at (when (and force-fall-secs (>= force-fall-secs 0.0))
                        (+ start-time force-fall-secs))]

    (try
      ;; Frame loop
      (loop [w world
             pres (make-pres-state)
             frame 0
             last-auto-t start-time
             vfx-events []
             last-vfx-t start-time]
        (let [t (glplat/Time)
              elapsed (- t start-time)
              should-close (glplat/ShouldClose)
              timed-out (and auto-exit-secs (>= elapsed auto-exit-secs))
              depth-prev (:depth w)]

          (if (or should-close timed-out (not (:running w)))
            (when dump?
              (print (str "XSOFY_GL_DUMP: exiting after " (int elapsed) "s, mode: " (:mode pres) "\n")))

            (do
              ;; Poll and process input events
              (glplat/PollEvents)
              (let [events (glplat/PollInputEvents)
                    ;; Process input: accumulate world changes and presentation facing
                    ;; Track whether any action was dispatched
                    [w-after-input pres-with-facing action-dispatched]
                    (reduce (fn [[world pres-acc action-flag] event-str]
                              (if-let [key (parse-glplat-event event-str)]
                                (let [action (input/parse-key key)
                                      ;; Interrupt auto-mode with real key presses
                                      world-interrupted (dissoc world :resting :running-dir
                                                                :autoexploring :auto-target)]
                                  (if (= (:mode pres-acc) :fp)
                                    ;; FP input remapping
                                    (let [remapped (fpview/remap-fp-input action (:facing pres-acc))
                                          final-action (:action remapped)
                                          new-facing (:facing remapped)
                                          pres-updated (assoc pres-acc :facing new-facing)
                                          world-dispatched (if final-action
                                                             (apply-auto-stops
                                                               (dispatch/dispatch
                                                                 world-interrupted
                                                                 final-action)
                                                               world)
                                                             world-interrupted)]
                                      [world-dispatched pres-updated true])
                                    ;; Top-down / falling: normal dispatch
                                    (let [world-dispatched (apply-auto-stops
                                                             (dispatch/dispatch
                                                               world-interrupted
                                                               action)
                                                             world)]
                                      [world-dispatched pres-acc true])))
                                [world pres-acc action-flag]))
                            [w pres false] events)

                    ;; Check if we should try auto-action (only if no input action this frame)
                    [w-final pres-with-facing last-auto-t-next]
                    (if (and (not action-dispatched)
                             (not= (:mode pres-with-facing) :falling)
                             (>= (- t last-auto-t) 0.06))
                      ;; Try auto-action
                      (if-let [auto-action (auto-key-for w-after-input)]
                        (let [w-auto (apply-auto-stops
                                       (dispatch/dispatch w-after-input auto-action)
                                       w-after-input)]
                          (when dump?
                            (print (str "XSOFY_GL_DUMP: auto-step " auto-action " turn "
                                     (:turn w-auto) "\n")))
                          [w-auto pres-with-facing t])
                        [w-after-input pres-with-facing last-auto-t])
                      [w-after-input pres-with-facing last-auto-t])

                    ;; Extract and accumulate vfx events from world
                    new-vfx-events (if-let [world-vfx (:vfx w-final)]
                                     (vec (concat vfx-events world-vfx))
                                     vfx-events)
                    w-no-vfx (dissoc w-final :vfx)

                    ;; Tick vfx if enough time has passed
                    [vfx-events-ticked last-vfx-t-next]
                    (if (and (seq new-vfx-events) (>= (- t last-vfx-t) 0.03))
                      [(vfx/tick-vfx new-vfx-events) t]
                      [new-vfx-events last-vfx-t])

                    ;; Advance presentation state (check for depth change)
                    ;; args: pres, NEW world, PREV world — order matters for the
                    ;; depth-increase check that triggers the fall.
                    pres' (advance-pres-state pres-with-facing w-no-vfx w t force-fall-at)]

                ;; Render frame
                (glplat/BeginFrame 0.1 0.1 0.15)
                (case (:mode pres')
                  :top-down (render-top-down w-no-vfx tex-id atlas dump? frame
                              vfx-events-ticked)
                  :falling (render-falling w-no-vfx pres' t tex-id atlas dump?
                             vfx-events-ticked)
                  :fp (render-first-person w-no-vfx pres' tex-id atlas dump? frame
                        vfx-events-ticked)
                  (render-top-down w-no-vfx tex-id atlas dump? frame
                    vfx-events-ticked))
                (render-hud w-no-vfx tex-id atlas)
                (glplat/EndFrame)

                ;; Continue loop
                (recur w-no-vfx pres' (inc frame) last-auto-t-next
                  vfx-events-ticked last-vfx-t-next))))))

      (finally
        (glplat/Terminate)
        (when dump?
          (print "XSOFY_GL_DUMP: terminated\n"))))))

(when-not *compiling-aot*
  (-main)
  ;; GLFW's main-thread lock keeps the process alive after -main returns;
  ;; exit explicitly (unlike main.lg, where the terminal loop needs no push).
  (os/exit 0))
