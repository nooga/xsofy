(ns xsofy.debug
  (:require [io :refer [open write! flush! close!]]))

(def log-file (atom nil))

(defn ensure-log []
  (when (nil? @log-file)
    (reset! log-file (open "debug.log" :append))))

(defn log [& args]
  (when-not *in-wasm*
    (ensure-log)
    (when @log-file
      (write! @log-file (str (apply str (interpose " " args)) "\n"))
      (flush! @log-file))))

(defn close-log []
  (when @log-file
    (close! @log-file)
    (reset! log-file nil)))
