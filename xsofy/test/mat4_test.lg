;; ==========================================================
;; Matrix-Vector Multiplication
;; ==========================================================

(deftest mul-v-with-identity
  (testing "identity * vec4 = vec4"
    (let [i (m/identity-m)
          v [1 2 3 1]]
      (is (approx-vec= v (m/mul-v i v))))))

(deftest mul-v-zero-vector
  (testing "any matrix * [0 0 0 0] = [0 0 0 0]"
    (let [m (m/translate [1 2 3])
          v [0 0 0 0]]
      (is (approx-vec= v (m/mul-v m v))))))

;; ==========================================================
;; Translation
;; ==========================================================

(deftest translate-basic
  (testing "translate creates translation matrix"
    (let [t (m/translate [1 2 3])
          v [0 0 0 1]]
      (is (approx-vec= [1 2 3 1] (m/mul-v t v))))))

(deftest translate-chained
  (testing "two translations compose"
    (let [t1 (m/translate [1 2 3])
          t2 (m/translate [4 5 6])
          combined (m/mul t1 t2)
          v [0 0 0 1]]
      ;; First apply t2 (shift by [4 5 6]), then t1 (shift by [1 2 3])
      (is (approx-vec= [5 7 9 1] (m/mul-v combined v))))))

;; ==========================================================
;; Scale
;; ==========================================================

(deftest scale-basic
  (testing "scale creates scaling matrix"
    (let [s (m/scale [2 3 4])
          v [1 1 1 1]]
      (is (approx-vec= [2 3 4 1] (m/mul-v s v))))))

(deftest scale-zero-component
  (testing "scale with a zero component projects to a plane"
    (let [s (m/scale [1 1 0])
          v [1 2 3 1]]
      (is (approx-vec= [1 2 0 1] (m/mul-v s v))))))

;; ==========================================================
;; Rotation X
;; ==========================================================

(deftest rotate-x-zero
  (testing "rotate-x by 0 is identity"
    (let [r (m/rotate-x 0)
          v [1 2 3 1]]
      (is (approx-vec= v (m/mul-v r v))))))

(deftest rotate-x-90
  (testing "rotate-x by π/2 swaps y and z"
    (let [r (m/rotate-x (/ 3.14159265359 2))
          v [1 0 0 1]]
      (is (approx-vec= [1 0 0 1] (m/mul-v r v)))))
  (testing "rotate-x by π/2 on Y-axis"
    (let [r (m/rotate-x (/ 3.14159265359 2))
          v [0 1 0 1]]
      (is (approx-vec= [0 0 1 1] (m/mul-v r v))))))

(deftest rotate-x-180
  (testing "rotate-x by π negates y and z"
    (let [r (m/rotate-x 3.14159265359)
          v [1 2 3 1]]
      (is (approx-vec= [1 -2 -3 1] (m/mul-v r v))))))

;; ==========================================================
;; Rotation Y
;; ==========================================================

(deftest rotate-y-zero
  (testing "rotate-y by 0 is identity"
    (let [r (m/rotate-y 0)
          v [1 2 3 1]]
      (is (approx-vec= v (m/mul-v r v))))))

(deftest rotate-y-90
  (testing "rotate-y by π/2 swaps x and z"
    (let [r (m/rotate-y (/ 3.14159265359 2))
          v [1 0 0 1]]
      (is (approx-vec= [0 0 -1 1] (m/mul-v r v))))))

;; ==========================================================
;; Rotation Z
;; ==========================================================

(deftest rotate-z-zero
  (testing "rotate-z by 0 is identity"
    (let [r (m/rotate-z 0)
          v [1 2 3 1]]
      (is (approx-vec= v (m/mul-v r v))))))

(deftest rotate-z-90
  (testing "rotate-z by π/2 swaps x and y"
    (let [r (m/rotate-z (/ 3.14159265359 2))
          v [1 0 0 1]]
      (is (approx-vec= [0 1 0 1] (m/mul-v r v))))))

;; ==========================================================
;; Perspective Projection
;; ==========================================================

(deftest perspective-basic
  (testing "perspective produces a 16-element matrix"
    (let [p (m/perspective (/ 3.14159265359 4) 1.0 0.1 100)]
      (is (= 16 (count p))))))

(deftest perspective-maps-near-plane
  (testing "perspective maps near plane (0,0,near) to (0,0,-1) in NDC (approximately)"
    (let [p (m/perspective (/ 3.14159265359 4) 1.0 1.0 100)
          ;; Point on near plane
          v (m/mul-v p [0 0 -1 1])]
      ;; After perspective divide, z should be close to -1
      (is (approx= -1 (/ (nth v 2) (nth v 3)))))))

;; ==========================================================
;; Orthographic Projection
;; ==========================================================

(deftest ortho-basic
  (testing "ortho produces a 16-element matrix"
    (let [o (m/ortho -10 10 -10 10 0.1 100)]
      (is (= 16 (count o))))))

(deftest ortho-center-maps-to-origin
  (testing "ortho maps center of frustum to (0, 0, z) in NDC"
    (let [o (m/ortho -10 10 -10 10 1 100)
          v (m/mul-v o [0 0 -1 1])]
      (is (approx= 0 (nth v 0)))
      (is (approx= 0 (nth v 1))))))

;; ==========================================================
;; Look-At
;; ==========================================================

(deftest look-at-identity-pose
  (testing "look-at from origin looking forward"
    (let [la (m/look-at [0 0 1] [0 0 0] [0 1 0])]
      (is (= 16 (count la))))))

(deftest look-at-up-vector
  (testing "look-at with canonical up vector [0 1 0]"
    (let [eye [5 5 5]
          target [0 0 0]
          up [0 1 0]
          la (m/look-at eye target up)]
      (is (= 16 (count la))))))
