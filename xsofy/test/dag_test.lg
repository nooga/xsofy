(ns xsofy.test.dag-test
  (:require [test :refer [deftest is testing]]
            [xsofy.dag :as dag]
            [xsofy.world :as world]
            [xsofy.dispatch :as dispatch]))

(defn- gs0 [] (dag/make-game-state (world/make-world 40 20 7)))

(defn- item-with-slot [w slot]
  (first (filter #(= slot (get-in w [:entities % :item :slot]))
                 (get-in w [:entities :player :inventory]))))

(defn- cord-ids [w]
  (vec
    (filter #(= :knotted-cord (get-in w [:entities % :template]))
            (get-in w [:entities :player :inventory]))))

;; --- commit-id is the rolling :seed hash (O(1), already computed per turn) ---

(deftest commit-id-is-the-seed-hash
  (let [w (world/make-world 40 20 12345)]
    (is (= (:seed w) (dag/commit-id w)) "commit-id IS the world's :seed")
    (is (= (dag/commit-id w) (dag/commit-id w)) "stable")))

(deftest commit-id-distinguishes-by-action-history
  (let [w (world/make-world 40 20 7)
        a (dispatch/dispatch w :up)
        b (dispatch/dispatch w :down)]
    (is (not= (dag/commit-id a) (dag/commit-id b)) "different action → different id")
    (is (= (dag/commit-id a) (dag/commit-id (dispatch/dispatch w :up)))
        "same action → same id (deterministic content address)")))

;; --- checkpoint-hash: optional full content hash, distinct from :seed ---

(deftest checkpoint-hash-catches-non-history-content
  (let [w     (world/make-world 40 20 7)
        w-fov (update w :fov conj [999 999])]
    (is (= (dag/checkpoint-hash w) (dag/checkpoint-hash w)) "stable")
    (is (not= (dag/checkpoint-hash w) (dag/checkpoint-hash w-fov))
        "full content hash reflects a non-history mutation")
    (is (= (dag/commit-id w) (dag/commit-id w-fov))
        "...while commit-id (:seed) does NOT — which is why the full hash is a checkpoint")))

;; --- game-state wrapper ---

(deftest make-game-state-wraps-initial-world
  (let [w  (world/make-world 40 20 7)
        gs (dag/make-game-state w)]
    (is (identical? w (dag/head-world gs)))
    (is (= (dag/commit-id w) (:head gs)))
    (is (= 1 (count (:nodes gs))))
    (is (= (:commit-id (:origin gs)) (:head gs)) "origin checkpoint is the root")
    (is (= 1000 (:max-nodes (:budget gs))))))

;; --- dispatch-gs: replay action logs a node; UI action does not ---

(deftest dispatch-gs-logs-replay-action
  (let [g0 (gs0)
        g1 (dag/dispatch-gs g0 :up)]
    (is (not= (:head g0) (:head g1)) "head advanced")
    (is (= 2 (count (:nodes g1))) "one node logged")
    (is (= (:head g0) (dag/parent-id g1 (:head g1))) "parent is the prior head")
    (is (= (dag/commit-id (dispatch/dispatch (dag/head-world g0) :up))
           (dag/commit-id (dag/head-world g1)))
        "HEAD world matches the world-level dispatch")))

(deftest dispatch-gs-ui-action-updates-world-without-logging
  (let [g0 (gs0)
        g1 (dag/dispatch-gs g0 :help)]   ;; :help is a UI action
    (is (= (:head g0) (:head g1)) "no new commit")
    (is (= 1 (count (:nodes g1))) "nothing logged")
    ;; the world update MUST still propagate so the screen toggles — otherwise
    ;; help/inventory/menu screens would silently never open
    (is (= :help (:screen (dag/head-world g1))) "screen toggled into :world")))

(deftest cast-runes-knot-creates-a-cord-and-pins-head
  (let [g0      (gs0)
        root    (:head g0)
        action  {:type :cast-runes :runes [:knot]}
        g1      (dag/dispatch-gs g0 action)
        cords   (cord-ids (dag/head-world g1))
        cord-id (first cords)]
    (is (= 1 (count cords)) "exactly one knot cord added to inventory")
    (is (= 2 (count (:nodes g1))) "casting knot records a new commit")
    (is (not= root (:head g1)) "HEAD advances to the post-knot commit")
    (is (= root (get-in g1 [:refs cord-id])) "cord ref pins the pre-cast HEAD")
    (is (= :knotted-cord (get-in (dag/head-world g1) [:entities cord-id :template])))))

(deftest use-knot-cord-restores-world-but-keeps-current-self
  (let [g0        (gs0)
        weapon    (item-with-slot (dag/head-world g0) :weapon)
        knot-gs   (dag/dispatch-gs g0 {:type :cast-runes :runes [:knot]})
        cord-id   (first (cord-ids (dag/head-world knot-gs)))
        knot-head (get-in knot-gs [:refs cord-id])
        root-pos  (get-in (dag/peek knot-gs knot-head) [:entities :player :pos])
        moved-gs  (-> knot-gs
                      (dag/dispatch-gs {:type :unequip :id weapon})
                      (dag/dispatch-gs :up))
        before    (dag/head-world moved-gs)
        turn-now  (:turn before)
        hp-now    (get-in before [:entities :player :body :hp])
        g'        (dag/dispatch-gs moved-gs {:type :use-item :id cord-id})
        after     (dag/head-world g')]
    (is (not= root-pos (get-in before [:entities :player :pos])) "precondition: player moved away from knot")
    (is (= root-pos (get-in after [:entities :player :pos])) "player snaps back to the knot position")
    (is (nil? (get-in after [:entities :player :equipment :weapon])) "current equipment state is preserved")
    (is (some #{weapon} (get-in after [:entities :player :inventory])) "unequipped weapon stays in inventory")
    (is (= hp-now (get-in after [:entities :player :body :hp])) "current HP is preserved")
    (is (= turn-now (:turn after)) "global turn counter does not rewind")
    (is (empty? (cord-ids after)) "the knot cord is consumed")
    (is (nil? (get-in g' [:refs cord-id])) "the consumed cord ref is removed")
    (is (= knot-head (dag/parent-id g' (:head g'))) "the unwind commit branches from the knot")))

(deftest use-knot-cord-with-dangling-ref-fizzles-cleanly
  (let [g0      (dag/dispatch-gs (gs0) {:type :cast-runes :runes [:knot]})
        cord-id (first (cord-ids (dag/head-world g0)))
        broken  (assoc-in g0 [:refs cord-id] 424242)
        g'      (dag/dispatch-gs broken {:type :use-item :id cord-id})
        after   (dag/head-world g')]
    (is (= (:head broken) (:head g')) "HEAD stays put when the knot target is gone")
    (is (some #{cord-id} (get-in after [:entities :player :inventory])) "cord is not consumed on a fizzle")
    (is (= 424242 (get-in g' [:refs cord-id])) "broken ref stays intact for now")))

;; --- materialize / peek: regenerate a past world by replay ---

(deftest peek-regenerates-past-world-by-replay
  (let [g0   (gs0)
        root (:head g0)
        g1   (dag/dispatch-gs g0 :up)]
    (is (= (:head g1) (dag/commit-id (dag/head-world g1))) "HEAD is live")
    (is (= root (dag/commit-id (dag/peek g1 root))) "root regenerated by replay")
    (is (nil? (dag/peek g1 424242)) "unknown id → nil")))

(deftest switch-head-time-travels
  (let [g0   (gs0)
        root (:head g0)
        g1   (dag/dispatch-gs g0 :up)
        g2   (dag/switch-head g1 root)]
    (is (= root (:head g2)))
    (is (= root (dag/commit-id (dag/head-world g2))) "world reverted to root")))

(deftest walk-parents-finds-nth-ancestor
  (let [g    (-> (gs0) (dag/dispatch-gs :up) (dag/dispatch-gs :down))
        root (:commit-id (:origin g))]
    (is (= root (dag/walk-parents g 2)) "2 back from head = root")
    (is (nil? (dag/walk-parents g 99)) "past the root → nil")))

;; --- branch: take a different real action from a past commit ---

(deftest branch-keeps-both-timelines
  (let [g     (-> (gs0) (dag/dispatch-gs :up) (dag/dispatch-gs :up))
        b-tip (:head g)
        root  (:commit-id (:origin g))
        g'    (dag/branch g root :down)   ;; diverge from root with a real action
        new-tip (:head g')]
    (is (not= new-tip b-tip) "new branch tip differs from the old timeline")
    (is (= root (dag/parent-id g' new-tip)) "new commit's parent is root")
    (is (some? (dag/peek g' b-tip)) "old timeline still regenerable")))

;; --- GC: prune unreachable branches ---

(deftest gc-prunes-unreachable-branches
  (let [g       (-> (gs0) (dag/dispatch-gs :up) (dag/dispatch-gs :up))
        b-tip   (:head g)
        root    (:commit-id (:origin g))
        ;; diverge from root with a different action — HEAD moves onto it
        g2      (dag/branch g root :down)
        down-tip (:head g2)
        ;; switch HEAD back to the original branch; the :down branch now has
        ;; nothing pointing at it
        g3      (dag/switch-head g2 b-tip)
        gced    (dag/gc g3)]
    (is (some? (dag/peek gced b-tip)) "HEAD's branch survives")
    (is (some? (dag/peek gced root)) "common ancestor (root) survives")
    (is (nil? (dag/peek gced down-tip)) "abandoned branch is pruned")
    (is (not (contains? (:nodes gced) down-tip)) "...and its node is gone")))

(deftest gc-keeps-ref-pinned-branches
  (let [g        (-> (gs0) (dag/dispatch-gs :up))
        a        (:head g)
        root     (:commit-id (:origin g))
        g2       (dag/branch g root :down)        ;; HEAD now on the :down branch
        ;; pin the otherwise-abandoned :up branch with a named ref
        g3       (assoc-in g2 [:refs :bookmark] a)
        gced     (dag/gc g3)]
    (is (some? (dag/peek gced a)) "ref-pinned branch survives GC")
    (is (some? (dag/peek gced (:head g2))) "HEAD branch survives GC")))

;; --- replay-gs determinism ---

(deftest replay-gs-reconstructs-identical-head
  (let [actions  [:up :up :up]
        live     (reduce dag/dispatch-gs (gs0) actions)
        replayed (dag/replay-gs 40 20 7 actions)]
    (is (= (:head live) (:head replayed)))))

;; --- dev-only undo ---

(deftest undo-walks-head-back-one-commit
  (let [g0   (gs0)
        root (:head g0)
        g1   (dag/dispatch-gs g0 :up)
        g2   (dag/undo g1)]
    (is (= root (:head g2)) "back to the pre-action commit")
    (is (= root (dag/commit-id (dag/head-world g2))) "world reverted")
    (is (some? (dag/peek g2 (:head g1))) "the undone commit is still in the log")))

(deftest undo-at-root-is-noop
  (let [g0 (gs0)]
    (is (= (:head g0) (:head (dag/undo g0))))))
